        <mxCell id="85aNvqyfkrdHRXoaKzfM-2" value="The software will allow users to:&lt;br&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Analyze and visualize transmission clusters of pathogens to understand their&lt;/div&gt;&lt;div&gt;spread using various different approaches.&lt;/div&gt;" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;spacingLeft=4;spacingRight=4;overflow=hidden;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;rotatable=0;whiteSpace=wrap;html=1;" parent="85aNvqyfkrdHRXoaKzfM-1" vertex="1">
