        <mxCell id="85aNvqyfkrdHRXoaKzfM-10" value="&lt;ol&gt;&lt;li&gt;Use a SNV threshold-free approach for transmission cluster detection.&lt;/li&gt;&lt;li&gt;Extend the package to also compare and contrast other threshold-based or threshold-free approaches.&lt;/li&gt;&lt;/ol&gt;" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;spacingLeft=4;spacingRight=4;overflow=hidden;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;rotatable=0;whiteSpace=wrap;html=1;" parent="85aNvqyfkrdHRXoaKzfM-9" vertex="1">
