        <mxCell id="85aNvqyfkrdHRXoaKzfM-6" value="&lt;ol&gt;&lt;li&gt;Read data&lt;/li&gt;&lt;li&gt;Implement basic cluster algorithm&lt;/li&gt;&lt;li&gt;Generate visualization plots and summary statistics&lt;/li&gt;&lt;li&gt;Extend to other types of datasets&lt;/li&gt;&lt;li&gt;Implement additional algorithms&lt;/li&gt;&lt;/ol&gt;" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;spacingLeft=4;spacingRight=4;overflow=hidden;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;rotatable=0;whiteSpace=wrap;html=1;" parent="85aNvqyfkrdHRXoaKzfM-5" vertex="1">
